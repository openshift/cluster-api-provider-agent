# Build the manager binary
FROM brew.registry.redhat.io/rh-osbs/openshift-golang-builder:rhel_9_1.25@sha256:071786da0259b1c8488b05aaa7e8ad3e93d601b578b532bc11f78f5e8926c6d3 as builder

WORKDIR /workspace
COPY . .
# Build
RUN CGO_ENABLED=1 go build -a -o manager main.go

FROM registry.redhat.io/rhel9-2-els/rhel:9.2@sha256:5d17f9559d14be797416aa8189fbd9faaecd9f406ea2c4c8ca70a9d534fc16a9

ARG version=2.9

LABEL \
    name="multicluster-engine/cluster-api-provider-agent-rhel9" \
    cpe="cpe:/a:redhat:multicluster_engine:2.9::el9" \
    com.redhat.component="cluster-api-provider-agent" \
    description="Kubernetes-native declarative infrastructure for agent-based installation. \
    cluster-api-provider-agent serves as infrastructure provider for Kubernetes cluster-api." \
    io.k8s.description="Kubernetes-native declarative infrastructure for agent-based installation. \
    cluster-api-provider-agent serves as infrastructure provider for Kubernetes cluster-api." \
    summary="Kubernetes-native declarative infrastructure for agent-based installation." \
    io.k8s.display-name="cluster-api-provider-agent" \
    io.openshift.tags="mce hypershift cluster-api-provider-agent" \
    version="${version}" \
    release="${version}" \
    distribution-scope="public" \
    url="https://github.com/openshift/cluster-api-provider-agent" \
    vendor="Red Hat, Inc."

WORKDIR /
COPY --from=builder /workspace/manager .
USER 65532:65532

ENTRYPOINT ["/manager"]
